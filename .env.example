# Copy this file to .env.local and fill in your values.
# Find them at: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — wire a vendor adapter in src/instrumentation.ts
# ERROR_REPORTING_DSN=

# Node environment (set automatically in most hosts)
# NODE_ENV=production

# Required for `npm run db:migrate` — from Supabase Dashboard → Connect → Session pooler → URI
# (Use Session pooler, not Direct connection, if db.[ref].supabase.co gives ENOTFOUND on your network.)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-1-[region].pooler.supabase.com:5432/postgres
